{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["must_cover_missing", "must_not_assert_violations"],
  "properties": {
    "must_cover_missing": {"$ref": "#/$defs/findings"},
    "must_not_assert_violations": {"$ref": "#/$defs/findings"}
  },
  "$defs": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item", "reason"],
        "properties": {
          "item": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
